# Copy this file to `.env.local` (recommended) or `.env` and fill in values.
# NOTE: Never commit real secrets. Only commit this template.
#
# Prisma + repo scripts load env vars from `.env.local` / `.env` automatically.

# --- Database (Prisma) ---
# Supabase Postgres connection string (pooled is fine for runtime)
DATABASE_URL=
# Supabase direct connection string (recommended for migrations)
DIRECT_URL=
# Optional runtime pool tuning for `pg` + Prisma adapter.
# Keep this low on Supabase Session mode to avoid MaxClientsInSessionMode.
PG_POOL_MAX=
PG_CONNECT_TIMEOUT_MS=
PG_IDLE_TIMEOUT_MS=

# --- Supabase (Public / Browser) ---
# Used by the Next.js app + Supabase SSR helpers
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional fallbacks (server-side) if you prefer these names
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Supabase (Server / Service Role) ---
# Required for admin APIs and server-side storage operations
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket names (optional; defaults are shown)
SUPABASE_STORAGE_BUCKET=listing-images
SUPABASE_USER_DOCS_BUCKET=user-documents
SUPABASE_BOOKING_PHOTOS_BUCKET=booking-photos
SUPABASE_LISTING_DOCS_BUCKET=listing-documents

# Public app origin used in Stripe success/cancel URLs
APP_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Web Push (optional) ---
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=

# --- Manual EFT (optional; South Africa) ---
EFT_BANK_NAME=
EFT_ACCOUNT_NAME=
EFT_ACCOUNT_NUMBER=
EFT_BRANCH_CODE=

# --- Admin helper scripts (optional) ---
ADMIN_INITIAL_PASSWORD=
ADMIN_INITIAL_PASSWORD_BASE=
ADMIN_INITIAL_PASSWORD_START=

# --- Seed data (optional) ---
ADMIN_EMAIL=admin@rideshare.local
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Admin
SEED_HOST_EMAIL=host@rideshare.local
SEED_HOST_PASSWORD=Host123!
SEED_HOST_NAME=Test Host
SEED_RENTER_EMAIL=renter@rideshare.local
SEED_RENTER_PASSWORD=Renter123!
SEED_RENTER_NAME=Test Renter
